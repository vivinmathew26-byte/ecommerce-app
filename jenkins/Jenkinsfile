pipeline {
    agent any

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-credentials')
        GITHUB_CREDENTIALS    = credentials('github_vivinmathew26-byte_credentials')
        DOCKERHUB_USER        = "vivinsdevops"
        BACKEND_IMAGE         = "${DOCKERHUB_USER}/ecommerce-backend"
        FRONTEND_IMAGE        = "${DOCKERHUB_USER}/ecommerce-frontend"
        IMAGE_TAG             = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                echo '📥 Pulling code from GitHub...'
                git credentialsId: 'github_vivinmathew26-byte_credentials',
                    url: 'https://github.com/vivinmathew26-byte/Ecommerce-app',
                    branch: 'main'
            }
        }

        stage('Test Backend') {
    steps {
        echo '🧪 Verifying tools...'
        sh '''
            export PATH=$PATH:/usr/local/bin
            docker --version
            kubectl version --client
            echo "✅ Tools ready!"
        '''
    }
}
        

        stage('Build Images') {
            parallel {
                stage('Build Backend') {
                    steps {
                        echo '🐳 Building backend image...'
                        sh """
                            docker build \
                                -t ${BACKEND_IMAGE}:${IMAGE_TAG} \
                                -t ${BACKEND_IMAGE}:latest \
                                ./backend
                        """
                    }
                }
                stage('Build Frontend') {
                    steps {
                        echo '🐳 Building frontend image...'
                        sh """
                            docker build \
                                -t ${FRONTEND_IMAGE}:${IMAGE_TAG} \
                                -t ${FRONTEND_IMAGE}:latest \
                                ./frontend
                        """
                    }
                }
            }
        }

        stage('Push to DockerHub') {
            steps {
                echo '📤 Pushing to DockerHub...'
                sh """
                    echo ${DOCKERHUB_CREDENTIALS_PSW} | docker login \
                        -u ${DOCKERHUB_CREDENTIALS_USR} --password-stdin
                    docker push ${BACKEND_IMAGE}:${IMAGE_TAG}
                    docker push ${BACKEND_IMAGE}:latest
                    docker push ${FRONTEND_IMAGE}:${IMAGE_TAG}
                    docker push ${FRONTEND_IMAGE}:latest
                    docker logout
                """
            }
        }

        stage('Deploy to Kubernetes') {
    steps {
        echo '☸️ Deploying to Kubernetes...'
        sh '''
            export PATH=$PATH:/usr/local/bin

            sed -i "s|yourdockerhub/ecommerce-backend:.*|vivinsdevops/ecommerce-backend:${IMAGE_TAG}|g" k8s/base/backend.yaml
            sed -i "s|yourdockerhub/ecommerce-frontend:.*|vivinsdevops/ecommerce-frontend:${IMAGE_TAG}|g" k8s/base/frontend.yaml

            kubectl apply -f k8s/base/namespace.yaml
            kubectl apply -f k8s/base/configmap.yaml
            kubectl apply -f k8s/base/secrets.yaml
            kubectl apply -f k8s/base/postgres.yaml

            echo "⏳ Waiting for postgres..."
            kubectl wait --for=condition=ready pod -l app=postgres -n ecommerce --timeout=120s

            kubectl apply -f k8s/base/backend.yaml
            kubectl apply -f k8s/base/frontend.yaml
            kubectl apply -f k8s/base/ingress.yaml

            kubectl rollout status deployment/backend -n ecommerce --timeout=300s
            kubectl rollout status deployment/frontend -n ecommerce --timeout=300s

            kubectl get pods -n ecommerce
        '''
    }
}

        stage('Health Check') {
            steps {
                echo '🏥 Health check...'
                sh """
                    sleep 15
                    kubectl get pods -n ecommerce
                    echo '✅ Deployment complete!'
                """
            }
        }
    }

    post {
        success {
            echo "✅ Build #${BUILD_NUMBER} deployed successfully!"
        }
        failure {
            echo "❌ Build #${BUILD_NUMBER} failed!"
        }
        always {
            sh """
                docker rmi ${BACKEND_IMAGE}:${IMAGE_TAG} || true
                docker rmi ${FRONTEND_IMAGE}:${IMAGE_TAG} || true
            """
        }
    }
}
